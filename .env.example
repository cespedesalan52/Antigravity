# ========================================
# Conocimiento Abierto - Variables de Entorno
# ========================================
# Copia este archivo como .env y ajusta los valores según tu entorno.

# URL de conexión a PostgreSQL
# Formato: postgresql://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/biblioteca_db

# Nombre del proyecto (usado en la documentación de la API)
PROJECT_NAME=Conocimiento Abierto

# Clave secreta para firmar los tokens de sesión (HMAC-SHA256).
# Generá una aleatoria, por ejemplo con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIAR-ESTA-CLAVE-POR-UNA-ALEATORIA-Y-SECRETA

# Minutos de validez del token de acceso (8 horas por defecto)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Entorno de ejecución: "development" o "production".
# En "production" la app NO arranca si SECRET_KEY quedó con el valor por defecto.
ENVIRONMENT=development

# Orígenes permitidos para CORS, separados por coma. Como el frontend se sirve
# desde la misma app, normalmente alcanza con el dominio propio. En producción,
# poné acá tu dominio (ej: https://biblioteca.tu-dominio.com).
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
